{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aips.dev/schemas/profile.schema.json",
  "title": "AIPS Profile",
  "description": "Draft JSON Schema for an Agent Internet Protocol Suite profile document. This schema describes cross-protocol metadata and does not replace A2A, MCP, AP2, OpenAPI, OAuth, or other protocol-native schemas.",
  "type": "object",
  "required": ["aips_version", "profile_type", "service", "protocols", "capability_profiles"],
  "properties": {
    "aips_version": {
      "type": "string"
    },
    "profile_type": {
      "type": "string",
      "enum": ["service", "agent", "registry", "local_gateway"]
    },
    "service": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "homepage": {
          "type": "string",
          "format": "uri"
        },
        "provider": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "contact": {
              "type": "string"
            }
          }
        }
      }
    },
    "protocols": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["protocol"],
        "properties": {
          "protocol": {
            "type": "string",
            "enum": ["a2a", "mcp", "ap2", "openapi", "http", "custom"]
          },
          "version": {
            "type": "string"
          },
          "discovery_url": {
            "type": "string",
            "format": "uri"
          },
          "server_url": {
            "type": "string",
            "format": "uri"
          },
          "transport": {
            "type": "string"
          },
          "auth": {
            "type": "object"
          },
          "metadata": {
            "type": "object"
          }
        }
      }
    },
    "capability_profiles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "backing_protocol", "backing_reference", "permissions", "risk_level"],
        "properties": {
          "id": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "backing_protocol": {
            "type": "string",
            "enum": ["a2a", "mcp", "ap2", "openapi", "http", "custom"]
          },
          "backing_reference": {
            "type": "string"
          },
          "permissions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "risk_level": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          },
          "confirmation_required": {
            "type": "boolean"
          },
          "audit_required": {
            "type": "boolean"
          },
          "cost_profile": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": ["free", "metered", "subscription", "quota", "negotiated"]
              },
              "unit": {
                "type": "string"
              },
              "price": {
                "type": "number"
              },
              "currency": {
                "type": "string"
              }
            }
          },
          "data_classes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "user_visible_summary": {
            "type": "string"
          },
          "registry_categories": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "policy": {
      "type": "object",
      "properties": {
        "agent_allowed": {
          "type": "boolean"
        },
        "human_confirmation_required": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "default_deny_unknown_agents": {
          "type": "boolean"
        },
        "revocation_supported": {
          "type": "boolean"
        }
      }
    },
    "audit": {
      "type": "object",
      "properties": {
        "trace_required_for_risk_levels": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          }
        },
        "user_visible_summary_required": {
          "type": "boolean"
        },
        "retention_policy": {
          "type": "string"
        }
      }
    }
  }
}
